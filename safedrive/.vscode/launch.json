{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "safedrive (Flutter Chrome)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "program": "lib/main.dart",
      "args": ["--web-renderer", "html"]
    },
    {
      "name": "safedrive (Flutter Windows)",
      "request": "launch",
      "type": "dart",
      "deviceId": "windows",
      "program": "lib/main.dart"
    },
    {
      "name": "safedrive (Profile Mode)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "program": "lib/main.dart",
      "flutterMode": "profile"
    }
  ],
  "dart.flutterSdkPath": "C:\\flutter\\flutter"
}
